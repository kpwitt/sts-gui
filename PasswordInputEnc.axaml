<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        SizeToContent="WidthAndHeight"
        ShowInTaskbar="False"
        CanResize="False"
        Icon="/Assets/gfx/school-building.ico"
        x:Class="StS_GUI_Avalonia.PasswordInputEnc"
        Title="Bitte Passwort eingeben">
    <StackPanel Margin="5">
        <TextBlock>Passwort eingeben:</TextBlock>
        <TextBox PasswordChar="*" x:Name="pwInputUpper" />
        <TextBlock x:Name="tbInputLower">Passwort wiederholen:</TextBlock>
        <TextBox PasswordChar="*" x:Name="pwInputLower" />
        <Grid ColumnDefinitions="Auto,Auto" RowDefinitions="Auto" VerticalAlignment="Stretch">
            <Button Grid.Column="0" x:Name="btnOk" Click="ButtonOK_OnClick" IsDefault="True">Ok</Button>
            <Button Grid.Column="1" x:Name="btnCancel" Click="ButtonCancel_OnClick">Abbrechen</Button>
        </Grid>
    </StackPanel>
</Window>
